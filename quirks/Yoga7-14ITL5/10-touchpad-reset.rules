/* Allow members of the wheel group to restart the touchpad service without authentication */
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        action.lookup("unit") == "touchpad-resume-fix.service" &&
        subject.isInGroup("wheel")) {
        if (action.lookup("verb") == "start" || action.lookup("verb") == "restart") {
            return polkit.Result.YES;
        }
    }
});
